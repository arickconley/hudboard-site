---
import Layout from '../layouts/Layout.astro';

const logos = [
  {
    id: 'option3',
    name: 'Option 3: Stacked Notes',
    description: 'Three stacked note cards with depth. Clean layered look representing multiple notes.',
    file: '/logos/option3-connection.svg'
  },
  {
    id: 'option3b',
    name: 'Option 3B: Stacked + Indicator',
    description: 'Two stacked cards with real-time indicator dot. Cleaner, with live status.',
    file: '/logos/option3b-stacked-clean.svg'
  },
  {
    id: 'option3c',
    name: 'Option 3C: Fanned Cards',
    description: 'Slightly rotated overlapping cards for a dynamic, casual feel.',
    file: '/logos/option3c-centered.svg'
  },
  {
    id: 'option1',
    name: 'Option 1: HUD Lettermark',
    description: 'Stylized H with heads-up display corner brackets. Tech-forward, clean.',
    file: '/logos/option1-hud-lettermark.svg'
  },
  {
    id: 'option1b',
    name: 'Option 1B: Minimal HUD',
    description: 'Cleaner version with refined targeting reticle corners.',
    file: '/logos/option1b-minimal-hud.svg'
  },
  {
    id: 'option2',
    name: 'Option 2: Board + Real-time',
    description: 'Grid of note cards with animated pulse indicator. Shows the "board" concept with real-time updates.',
    file: '/logos/option2-board-realtime.svg'
  },
  {
    id: 'option4',
    name: 'Option 4: Geometric H',
    description: 'Bold, solid geometric H. Simple, memorable, scales well.',
    file: '/logos/option4-geometric-h.svg'
  },
  {
    id: 'option4b',
    name: 'Option 4B: Rounded H',
    description: 'Softer, friendlier version with rounded pill shapes.',
    file: '/logos/option4b-rounded-h.svg'
  }
];
---

<Layout title="HUDBoard Logo Options">
  <div class="min-h-screen py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">Logo Options</h1>
        <p class="text-xl text-gray-400">Choose the logo that best represents HUDBoard</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {logos.map((logo) => (
          <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden hover:border-primary-500 transition-colors">
            <!-- Logo preview area -->
            <div class="p-8 bg-gray-950 flex items-center justify-center">
              <img src={logo.file} alt={logo.name} class="w-32 h-32" />
            </div>

            <!-- Logo info -->
            <div class="p-6">
              <h3 class="text-lg font-semibold text-white mb-2">{logo.name}</h3>
              <p class="text-gray-400 text-sm mb-4">{logo.description}</p>

              <!-- Size previews -->
              <div class="flex items-center gap-4 pt-4 border-t border-gray-800">
                <div class="text-center">
                  <img src={logo.file} alt="" class="w-16 h-16 mx-auto mb-1" />
                  <span class="text-xs text-gray-500">64px</span>
                </div>
                <div class="text-center">
                  <img src={logo.file} alt="" class="w-10 h-10 mx-auto mb-1" />
                  <span class="text-xs text-gray-500">40px</span>
                </div>
                <div class="text-center">
                  <img src={logo.file} alt="" class="w-6 h-6 mx-auto mb-1" />
                  <span class="text-xs text-gray-500">24px</span>
                </div>
                <div class="text-center">
                  <img src={logo.file} alt="" class="w-4 h-4 mx-auto mb-1" />
                  <span class="text-xs text-gray-500">16px</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Light background preview -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">On Light Background</h2>
        <div class="bg-white rounded-xl p-8">
          <div class="flex flex-wrap items-center justify-center gap-8">
            {logos.map((logo) => (
              <div class="text-center">
                <img src={logo.file} alt={logo.name} class="w-20 h-20 mx-auto mb-2" />
                <span class="text-xs text-gray-600">{logo.id}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- With wordmark preview -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">With Wordmark</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {logos.map((logo) => (
            <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
              <div class="flex items-center gap-3">
                <img src={logo.file} alt="" class="w-10 h-10" />
                <span class="text-xl font-bold text-white">HUDBoard</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-16 text-center">
        <a href="/" class="text-primary-400 hover:text-primary-300 transition-colors">
          ← Back to landing page
        </a>
      </div>
    </div>
  </div>
</Layout>
