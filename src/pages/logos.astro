---
import Layout from '../layouts/Layout.astro';

const logos = [
  {
    id: 'option1b',
    name: 'Option 1B: HUD Board',
    description: 'HUD-style frame with note cards inside. The corners represent the "board" containing the notes.',
    file: '/logos/option1b-minimal-hud.svg'
  },
  {
    id: 'option3b',
    name: 'Option 3B: Perspective Stack',
    description: 'Stacked note cards with perspective - wider at bottom, narrower at top for depth.',
    file: '/logos/option3b-stacked-clean.svg'
  }
];
---

<Layout title="HUDBoard Logo Options">
  <div class="min-h-screen py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">Logo Options</h1>
        <p class="text-xl text-gray-400">Final two concepts</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {logos.map((logo) => (
          <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden hover:border-primary-500 transition-colors">
            <!-- Logo preview area -->
            <div class="p-12 bg-gray-950 flex items-center justify-center">
              <img src={logo.file} alt={logo.name} class="w-40 h-40" />
            </div>

            <!-- Logo info -->
            <div class="p-6">
              <h3 class="text-lg font-semibold text-white mb-2">{logo.name}</h3>
              <p class="text-gray-400 text-sm mb-4">{logo.description}</p>

              <!-- Size previews -->
              <div class="flex items-center gap-6 pt-4 border-t border-gray-800">
                <div class="text-center">
                  <img src={logo.file} alt="" class="w-16 h-16 mx-auto mb-1" />
                  <span class="text-xs text-gray-500">64px</span>
                </div>
                <div class="text-center">
                  <img src={logo.file} alt="" class="w-10 h-10 mx-auto mb-1" />
                  <span class="text-xs text-gray-500">40px</span>
                </div>
                <div class="text-center">
                  <img src={logo.file} alt="" class="w-8 h-8 mx-auto mb-1" />
                  <span class="text-xs text-gray-500">32px</span>
                </div>
                <div class="text-center">
                  <img src={logo.file} alt="" class="w-5 h-5 mx-auto mb-1" />
                  <span class="text-xs text-gray-500">20px</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Light background preview -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">On Light Background</h2>
        <div class="bg-white rounded-xl p-12">
          <div class="flex items-center justify-center gap-16">
            {logos.map((logo) => (
              <div class="text-center">
                <img src={logo.file} alt={logo.name} class="w-24 h-24 mx-auto mb-3" />
                <span class="text-sm text-gray-600 font-medium">{logo.id}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- With wordmark preview -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">With Wordmark</h2>
        <div class="space-y-6">
          {logos.map((logo) => (
            <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
              <div class="flex items-center gap-4">
                <img src={logo.file} alt="" class="w-12 h-12" />
                <span class="text-2xl font-bold text-white">HUDBoard</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Dark compact -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">Compact Header</h2>
        <div class="space-y-4">
          {logos.map((logo) => (
            <div class="bg-gray-950 border border-gray-800 rounded-lg px-4 py-3 inline-flex items-center gap-3 mr-4">
              <img src={logo.file} alt="" class="w-8 h-8" />
              <span class="text-lg font-bold text-white">HUDBoard</span>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-16 text-center">
        <a href="/" class="text-primary-400 hover:text-primary-300 transition-colors">
          ← Back to landing page
        </a>
      </div>
    </div>
  </div>
</Layout>
