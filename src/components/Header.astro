---
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2">
        <img src="/favicon.svg" alt="HUDBoard" class="w-8 h-8" />
        <span class="text-xl font-bold text-white">HUDBoard</span>
      </a>

      <!-- Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        <a href="#features" class="text-gray-400 hover:text-white transition-colors">Features</a>
        <a href="#how-it-works" class="text-gray-400 hover:text-white transition-colors">How It Works</a>
        <a href="#pricing" class="text-gray-400 hover:text-white transition-colors">Pricing</a>
      </div>

      <!-- CTA Button -->
      <a href="mailto:sales@hudboard.com" class="bg-primary-600 hover:bg-primary-500 text-white px-4 py-2 rounded-lg font-medium transition-colors">
        Request Demo
      </a>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('header');

  function updateHeader() {
    const scrollY = window.scrollY;
    const maxScroll = 100;
    const opacity = Math.min(scrollY / maxScroll, 1);

    if (scrollY > 10) {
      header?.classList.add('bg-gray-950/90', 'backdrop-blur-md', 'border-gray-800');
      header?.classList.remove('border-transparent');
      if (header) {
        header.style.backgroundColor = `rgba(3, 7, 18, ${0.5 + opacity * 0.4})`;
      }
    } else {
      header?.classList.remove('bg-gray-950/90', 'backdrop-blur-md', 'border-gray-800');
      header?.classList.add('border-transparent');
      if (header) {
        header.style.backgroundColor = 'transparent';
      }
    }
  }

  window.addEventListener('scroll', updateHeader);
  updateHeader();
</script>
