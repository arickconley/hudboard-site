---
const plans = [
  {
    name: "Business",
    price: "$99",
    period: "/month",
    description: "For call centers and teams",
    features: [
      "Up to 50 users",
      "Unlimited notes",
      "365-day archive retention",
      "Real-time updates",
      "Comments & collaboration",
      "Note expiration & pinning",
      "Archive with search",
      "Custom roles & permissions",
      "Custom branding",
      "API access",
      "Data export (CSV, JSON)",
      "Email support"
    ],
    cta: "Request Demo",
    popular: true
  },
  {
    name: "Enterprise",
    price: "$499",
    period: "/month",
    description: "For large organizations",
    features: [
      "Unlimited users",
      "Unlimited notes",
      "Unlimited archive retention",
      "Everything in Business, plus:",
      "Call signs module",
      "Audit logging",
      "SSO / SAML integration",
      "Webhooks",
      "SLA guarantee",
      "Dedicated support",
      "On-premise deployment option"
    ],
    cta: "Contact Sales",
    popular: false
  }
];
---

<section id="pricing" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Simple, transparent pricing
      </h2>
      <p class="text-xl text-gray-400">
        Choose the plan that fits your team. Request a demo to get started.
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {plans.map((plan) => (
        <div class={`relative bg-gray-900 rounded-xl p-8 border ${plan.popular ? 'border-primary-500 ring-2 ring-primary-500/20' : 'border-gray-800'}`}>
          {plan.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary-600 text-white text-sm font-medium px-4 py-1 rounded-full">
              Most Popular
            </div>
          )}

          <div class="text-center mb-8">
            <h3 class="text-xl font-semibold text-white mb-2">{plan.name}</h3>
            <div class="flex items-baseline justify-center gap-1">
              <span class="text-4xl font-bold text-white">{plan.price}</span>
              <span class="text-gray-400">{plan.period}</span>
            </div>
            <p class="text-gray-400 mt-2">{plan.description}</p>
          </div>

          <ul class="space-y-4 mb-8">
            {plan.features.map((feature) => (
              <li class={`flex items-center gap-3 ${feature.includes('Everything in') ? 'text-primary-400 font-medium mt-4 pt-4 border-t border-gray-800' : 'text-gray-300'}`}>
                {!feature.includes('Everything in') && (
                  <svg class="w-5 h-5 text-green-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                )}
                {feature}
              </li>
            ))}
          </ul>

          <a
            href="mailto:sales@hudboard.app"
            class={`block w-full text-center py-3 rounded-lg font-semibold transition-colors ${
              plan.popular
                ? 'bg-primary-600 hover:bg-primary-500 text-white'
                : 'bg-gray-800 hover:bg-gray-700 text-white border border-gray-700'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Add-on note -->
    <div class="text-center mt-12">
      <p class="text-gray-400">
        Need additional modules? <a href="mailto:sales@hudboard.app" class="text-primary-400 hover:text-primary-300">Contact us</a> about add-ons like Call Signs ($25/mo).
      </p>
    </div>
  </div>
</section>
