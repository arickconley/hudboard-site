---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 px-4 sm:px-6 lg:px-8 border-t border-gray-800">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center space-x-2 mb-4">
          <img src="/favicon.svg" alt="HUDBoard" class="w-8 h-8" />
          <span class="text-xl font-bold text-white">HUDBoard</span>
        </a>
        <p class="text-gray-400 text-sm">
          Real-time collaborative notes for call centers.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-white font-semibold mb-4">Product</h4>
        <ul class="space-y-2">
          <li><a href="#features" class="text-gray-400 hover:text-white transition-colors">Features</a></li>
          <li><a href="#pricing" class="text-gray-400 hover:text-white transition-colors">Pricing</a></li>
          <li><a href="#how-it-works" class="text-gray-400 hover:text-white transition-colors">How It Works</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-white font-semibold mb-4">Company</h4>
        <ul class="space-y-2">
          <li><a href="mailto:support@hudboard.com" class="text-gray-400 hover:text-white transition-colors">Support</a></li>
          <li><a href="mailto:sales@hudboard.com" class="text-gray-400 hover:text-white transition-colors">Contact Sales</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-white font-semibold mb-4">Legal</h4>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-gray-400 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-gray-400 hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">
        © {currentYear} HUDBoard. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://twitter.com/hudboard" class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://linkedin.com/company/hudboard" class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
