---
---

<section class="pt-32 pb-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary-950/50 to-transparent pointer-events-none"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-primary-950 border border-primary-800 text-primary-300 text-sm font-medium mb-8">
        <span class="w-2 h-2 bg-green-400 rounded-full mr-2 animate-pulse"></span>
        Real-time collaboration for call centers
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Keep your team
        <span class="gradient-text"> in sync</span>
        <br />with every call
      </h1>

      <!-- Subheadline -->
      <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
        HUDBoard is a real-time collaborative notes board built for call centers.
        Share notes instantly, track expirations, and never lose important information again.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="mailto:sales@hudboard.com" class="w-full sm:w-auto bg-primary-600 hover:bg-primary-500 text-white px-8 py-3 rounded-lg font-semibold text-lg transition-colors shadow-lg shadow-primary-600/25">
          Request a Demo
        </a>
        <a href="#how-it-works" class="w-full sm:w-auto bg-gray-800 hover:bg-gray-700 text-white px-8 py-3 rounded-lg font-semibold text-lg transition-colors border border-gray-700">
          See How It Works
        </a>
      </div>

      <!-- Social proof -->
      <div class="mt-12 flex items-center justify-center gap-8 text-gray-500">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>Personalized onboarding</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>Dedicated support</span>
        </div>
      </div>
    </div>

    <!-- Hero Image/Screenshot -->
    <div class="mt-16 relative">
      <div class="bg-gradient-to-t from-gray-950 via-transparent to-transparent absolute inset-0 z-10 pointer-events-none"></div>
      <div class="bg-gray-800 rounded-xl border border-gray-700 shadow-2xl overflow-hidden">
        <!-- Browser chrome -->
        <div class="bg-gray-900 px-4 py-3 flex items-center gap-2 border-b border-gray-700">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <div class="ml-4 flex-1 bg-gray-800 rounded-lg px-4 py-1.5 text-gray-400 text-sm">
            app.hudboard.app/dashboard
          </div>
        </div>

        <!-- App layout -->
        <div class="flex min-h-[420px]">
          <!-- Left sidebar - Pinned Notes -->
          <div class="hidden md:block w-64 bg-gray-700 border-r border-gray-600 p-4">
            <div class="flex items-center gap-2 mb-4 pb-3 border-b border-gray-600">
              <div class="p-1.5 bg-gray-600 rounded-lg">
                <svg class="w-4 h-4 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
                </svg>
              </div>
              <div>
                <h2 class="text-sm font-semibold text-white">Pinned Notes</h2>
                <p class="text-xs text-gray-400">2 items</p>
              </div>
            </div>
            <!-- Pinned note cards -->
            <div class="space-y-2">
              <div class="bg-gray-600 rounded-xl border-l-4 border-l-primary-400 p-3">
                <h3 class="font-semibold text-white text-sm mb-1">Acme Corp</h3>
                <p class="text-xs text-gray-400 mb-0.5">Enterprise Client</p>
                <p class="text-xs text-primary-400 font-medium mb-1.5">(555) 123-4567</p>
                <p class="text-sm text-gray-300 line-clamp-2">VIP client - escalate immediately...</p>
              </div>
              <div class="bg-gray-600 rounded-xl border-l-4 border-l-primary-400 p-3">
                <h3 class="font-semibold text-white text-sm mb-1">Server Room</h3>
                <p class="text-xs text-primary-400 font-medium mb-1.5">(555) 987-6543</p>
                <p class="text-sm text-gray-300 line-clamp-2">Access code: 4521#</p>
              </div>
            </div>
          </div>

          <!-- Main content -->
          <div class="flex-1 bg-gray-800 p-4 lg:p-6">
            <!-- Toolbar -->
            <div class="flex gap-3 items-center mb-4">
              <div class="flex-1 relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <div class="w-full pl-9 pr-4 py-2 bg-gray-700 border border-gray-600 rounded-xl text-gray-400 text-sm">
                  Search notes...
                </div>
              </div>
              <div class="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-primary-500 to-primary-600 text-white font-medium rounded-xl text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>New Note</span>
              </div>
            </div>

            <!-- Notes grid -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
              <!-- Note card 1 -->
              <div class="bg-gray-700 rounded-xl p-4 border border-gray-600 hover:border-gray-500 transition-colors">
                <div class="flex items-start justify-between mb-2">
                  <div>
                    <h3 class="font-semibold text-white">John Smith</h3>
                    <p class="text-xs text-gray-400">Billing Dept</p>
                  </div>
                  <span class="text-xs text-orange-400 bg-orange-400/10 px-2 py-1 rounded-full">2h left</span>
                </div>
                <p class="text-xs text-primary-400 font-medium mb-2">(555) 234-5678</p>
                <p class="text-sm text-gray-300 line-clamp-2 mb-3">Callback requested for billing inquiry. Customer wants to discuss invoice #4521.</p>
                <div class="flex items-center justify-between text-xs text-gray-500">
                  <span>By Sarah • 10:30 AM</span>
                  <div class="flex items-center gap-1 text-gray-400">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    <span>3</span>
                  </div>
                </div>
              </div>

              <!-- Note card 2 (selected) -->
              <div class="bg-gray-700 rounded-xl p-4 border-2 border-primary-500 ring-2 ring-primary-500/20">
                <div class="flex items-start justify-between mb-2">
                  <div>
                    <h3 class="font-semibold text-white">Jane Doe</h3>
                    <p class="text-xs text-gray-400">Support Ticket</p>
                  </div>
                  <span class="text-xs text-red-400 bg-red-400/10 px-2 py-1 rounded-full">30m left</span>
                </div>
                <p class="text-xs text-primary-400 font-medium mb-2">(555) 345-6789</p>
                <p class="text-sm text-gray-300 line-clamp-2 mb-3">Password reset completed. Customer confirmed access restored to account.</p>
                <div class="flex items-center justify-between text-xs text-gray-500">
                  <span>By Mike • 11:45 AM</span>
                  <div class="flex items-center gap-1 text-gray-400">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    <span>1</span>
                  </div>
                </div>
              </div>

              <!-- Note card 3 -->
              <div class="bg-gray-700 rounded-xl p-4 border border-gray-600 hover:border-gray-500 transition-colors">
                <div class="flex items-start justify-between mb-2">
                  <div>
                    <h3 class="font-semibold text-white">Robert Chen</h3>
                    <p class="text-xs text-gray-400">TechStart Inc</p>
                  </div>
                  <span class="text-xs text-green-400 bg-green-400/10 px-2 py-1 rounded-full">5h left</span>
                </div>
                <p class="text-xs text-primary-400 font-medium mb-2">(555) 456-7890</p>
                <p class="text-sm text-gray-300 line-clamp-2 mb-3">New account setup inquiry. Interested in Business plan features.</p>
                <div class="flex items-center justify-between text-xs text-gray-500">
                  <span>By Tom • 9:15 AM</span>
                  <div class="flex items-center gap-1 text-gray-400">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    <span>0</span>
                  </div>
                </div>
              </div>

              <!-- Note card 4 -->
              <div class="hidden lg:block bg-gray-700 rounded-xl p-4 border border-gray-600 hover:border-gray-500 transition-colors">
                <div class="flex items-start justify-between mb-2">
                  <div>
                    <h3 class="font-semibold text-white">Maria Garcia</h3>
                  </div>
                </div>
                <p class="text-xs text-primary-400 font-medium mb-2">(555) 567-8901</p>
                <p class="text-sm text-gray-300 line-clamp-2 mb-3">General inquiry about service hours and availability.</p>
                <div class="flex items-center justify-between text-xs text-gray-500">
                  <span>By Sarah • 8:30 AM</span>
                  <div class="flex items-center gap-1 text-gray-400">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    <span>2</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
