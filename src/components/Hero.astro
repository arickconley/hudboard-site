---
---

<section class="pt-32 pb-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary-950/50 to-transparent pointer-events-none"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-primary-950 border border-primary-800 text-primary-300 text-sm font-medium mb-8">
        <span class="w-2 h-2 bg-green-400 rounded-full mr-2 animate-pulse"></span>
        Real-time collaboration for call centers
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Keep your team
        <span class="gradient-text"> in sync</span>
        <br />with every call
      </h1>

      <!-- Subheadline -->
      <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
        HUDBoard is a real-time collaborative notes board built for call centers.
        Share notes instantly, track expirations, and never lose important information again.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#pricing" class="w-full sm:w-auto bg-primary-600 hover:bg-primary-500 text-white px-8 py-3 rounded-lg font-semibold text-lg transition-colors shadow-lg shadow-primary-600/25">
          Start Free Trial
        </a>
        <a href="#how-it-works" class="w-full sm:w-auto bg-gray-800 hover:bg-gray-700 text-white px-8 py-3 rounded-lg font-semibold text-lg transition-colors border border-gray-700">
          See How It Works
        </a>
      </div>

      <!-- Social proof -->
      <div class="mt-12 flex items-center justify-center gap-8 text-gray-500">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>No credit card required</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>14-day free trial</span>
        </div>
      </div>
    </div>

    <!-- Hero Image/Screenshot -->
    <div class="mt-16 relative">
      <div class="bg-gradient-to-t from-gray-950 via-transparent to-transparent absolute inset-0 z-10 pointer-events-none"></div>
      <div class="bg-gray-900 rounded-xl border border-gray-800 shadow-2xl overflow-hidden">
        <div class="bg-gray-800 px-4 py-3 flex items-center gap-2">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <span class="ml-4 text-gray-400 text-sm">app.hudboard.app</span>
        </div>
        <div class="p-8 min-h-[400px] flex items-center justify-center">
          <div class="text-gray-600 text-lg">
            <!-- Placeholder for screenshot -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 w-full max-w-4xl">
              <!-- Sample note cards -->
              <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-white font-medium">John Smith</span>
                  <span class="text-xs text-orange-400 bg-orange-400/10 px-2 py-1 rounded">2h left</span>
                </div>
                <p class="text-gray-400 text-sm">Callback requested for billing inquiry...</p>
                <div class="mt-3 flex items-center text-xs text-gray-500">
                  <span>By Sarah</span>
                  <span class="mx-2">•</span>
                  <span>10:30 AM</span>
                </div>
              </div>
              <div class="bg-gray-800 rounded-lg p-4 border border-primary-500/50 ring-2 ring-primary-500/20">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-white font-medium">Acme Corp</span>
                  <span class="text-xs text-red-400 bg-red-400/10 px-2 py-1 rounded">Urgent</span>
                </div>
                <p class="text-gray-400 text-sm">VIP client - escalate immediately if they call back...</p>
                <div class="mt-3 flex items-center text-xs text-gray-500">
                  <span>By Mike</span>
                  <span class="mx-2">•</span>
                  <span>9:15 AM</span>
                </div>
              </div>
              <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-white font-medium">Jane Doe</span>
                  <span class="text-xs text-green-400 bg-green-400/10 px-2 py-1 rounded">Resolved</span>
                </div>
                <p class="text-gray-400 text-sm">Password reset completed, customer confirmed...</p>
                <div class="mt-3 flex items-center text-xs text-gray-500">
                  <span>By Tom</span>
                  <span class="mx-2">•</span>
                  <span>8:45 AM</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
